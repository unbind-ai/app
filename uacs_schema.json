{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unbind.esali.com/uacs_schema.json",
  "title": "Universal AI Conversation Standard (UACS)",
  "description": "A universal JSON format for AI conversation data portability across platforms",
  "version": "1.0.0",
  "type": "object",
  "required": ["uacs_version", "conversations"],
  "properties": {
    "uacs_version": {
      "type": "string",
      "description": "Version of the UACS schema",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "export_metadata": {
      "type": "object",
      "description": "Metadata about the export process",
      "properties": {
        "exported_at": { "type": "string", "format": "date-time" },
        "exporter": { "type": "string" },
        "source_url": { "type": "string", "format": "uri" },
        "workspace_id": { "type": ["string", "null"], "description": "Teams/Enterprise workspace ID" },
        "workspace_name": { "type": ["string", "null"], "description": "Teams/Enterprise workspace name" },
        "account_type": { "type": ["string", "null"], "enum": ["free", "plus", "team", "enterprise", "unknown", null] }
      }
    },
    "statistics": {
      "type": "object",
      "properties": {
        "total_conversations": { "type": "integer", "minimum": 0 },
        "total_messages": { "type": "integer", "minimum": 0 },
        "conversations_with_errors": { "type": "integer", "minimum": 0 },
        "export_duration_ms": { "type": "integer", "minimum": 0 },
        "archived_conversations": { "type": "integer", "minimum": 0 }
      }
    },
    "personalization": {
      "type": ["object", "null"],
      "properties": {
        "memory": { "type": ["array", "null"] },
        "settings": { "type": ["object", "null"] },
        "custom_instructions": { "type": ["object", "null"] }
      }
    },
    "conversations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "source_platform", "messages"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "created_at": { "type": ["string", "null"], "format": "date-time" },
          "updated_at": { "type": ["string", "null"], "format": "date-time" },
          "source_platform": {
            "type": "string",
            "enum": ["chatgpt", "chatgpt_plus", "chatgpt_teams", "chatgpt_enterprise", "claude", "claude_pro", "gemini", "gemini_advanced", "grok", "perplexity", "deepseek", "mistral", "other"]
          },
          "context": {
            "type": ["object", "null"],
            "properties": {
              "system_prompt": { "type": ["string", "null"] },
              "custom_instructions": { "type": ["string", "null"] }
            }
          },
          "gizmo_id": { "type": ["string", "null"] },
          "is_archived": { "type": "boolean", "default": false },
          "is_shared": { "type": "boolean", "default": false },
          "share_url": { "type": ["string", "null"], "format": "uri" },
          "url": { "type": ["string", "null"], "format": "uri" },
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["role", "content"],
              "properties": {
                "id": { "type": ["string", "null"] },
                "role": { "type": "string", "enum": ["user", "assistant", "system", "tool"] },
                "content": { "type": "string" },
                "timestamp": { "type": ["string", "null"], "format": "date-time" },
                "model_name": { "type": ["string", "null"] },
                "token_usage": {
                  "type": ["object", "null"],
                  "properties": {
                    "prompt_tokens": { "type": ["integer", "null"] },
                    "completion_tokens": { "type": ["integer", "null"] },
                    "total_tokens": { "type": ["integer", "null"] }
                  }
                },
                "latency_ms": { "type": ["integer", "null"], "minimum": 0 },
                "attachments": {
                  "type": ["array", "null"],
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": { "type": ["string", "null"] },
                      "filename": { "type": ["string", "null"] },
                      "mime_type": { "type": ["string", "null"] },
                      "size_bytes": { "type": ["integer", "null"] },
                      "url": { "type": ["string", "null"] },
                      "type": { "type": ["string", "null"], "enum": ["uploaded_file", "uploaded_image", "generated_image", null] },
                      "dalle_prompt": { "type": ["string", "null"] }
                    }
                  }
                },
                "metadata": {
                  "type": ["object", "null"],
                  "description": "Additional message metadata (plugins, citations, etc.)"
                }
              }
            }
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": ["string", "null"] },
          "error": { "type": "string" }
        }
      }
    }
  }
}
